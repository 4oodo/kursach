<Window x:Class="kursach.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Администратор - Управление энергопотреблением" Height="700" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl>
            <TabItem Header="Управление зданиями">
                <Grid Background="White">
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Название здания:" VerticalAlignment="Center" Width="120"/>
                            <TextBox x:Name="BuildingNameTextBox" Width="200" Margin="10,0"/>
                            <TextBlock Text="Адрес:" VerticalAlignment="Center" Width="50" Margin="20,0,0,0"/>
                            <TextBox x:Name="BuildingAddressTextBox" Width="200" Margin="10,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button x:Name="AddBuildingBtn" Content="Добавить" Width="100" Click="AddBuildingBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="UpdateBuildingBtn" Content="Обновить" Width="100" Click="UpdateBuildingBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="DeleteBuildingBtn" Content="Удалить" Width="100" Click="DeleteBuildingBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="RefreshBuildingBtn" Content="Обновить список" Width="120" Click="RefreshBuildingBtn_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="BuildingDataGrid" AutoGenerateColumns="True" Height="450" MouseDoubleClick="BuildingDataGrid_MouseDoubleClick"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Управление категориями">
                <Grid Background="White">
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Название категории:" VerticalAlignment="Center" Width="120"/>
                            <TextBox x:Name="CategoryNameTextBox" Width="250" Margin="10,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button x:Name="AddCategoryBtn" Content="Добавить" Width="100" Click="AddCategoryBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="UpdateCategoryBtn" Content="Обновить" Width="100" Click="UpdateCategoryBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="DeleteCategoryBtn" Content="Удалить" Width="100" Click="DeleteCategoryBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="RefreshCategoryBtn" Content="Обновить список" Width="120" Click="RefreshCategoryBtn_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="CategoryDataGrid" AutoGenerateColumns="True" Height="500"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Управление периодами">
                <Grid Background="White">
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Название периода:" VerticalAlignment="Center" Width="120"/>
                            <TextBox x:Name="TimePeriodNameTextBox" Width="250" Margin="10,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button x:Name="AddTimePeriodBtn" Content="Добавить" Width="100" Click="AddTimePeriodBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="UpdateTimePeriodBtn" Content="Обновить" Width="100" Click="UpdateTimePeriodBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="DeleteTimePeriodBtn" Content="Удалить" Width="100" Click="DeleteTimePeriodBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="RefreshTimePeriodBtn" Content="Обновить список" Width="120" Click="RefreshTimePeriodBtn_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="TimePeriodDataGrid" AutoGenerateColumns="True" Height="500"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Управление помещениями">
                <Grid Background="White">
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Здание:" VerticalAlignment="Center" Width="100"/>
                            <ComboBox x:Name="RoomBuildingCombo" Width="180" Margin="10,0"/>
                            <TextBlock Text="Этаж:" VerticalAlignment="Center" Width="50" Margin="20,0,0,0"/>
                            <TextBox x:Name="RoomFloorTextBox" Width="80" Margin="10,0"/>
                            <TextBlock Text="Категория:" VerticalAlignment="Center" Width="70" Margin="20,0,0,0"/>
                            <ComboBox x:Name="RoomCategoryCombo" Width="180" Margin="10,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button x:Name="AddRoomBtn" Content="Добавить" Width="100" Click="AddRoomBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="UpdateRoomBtn" Content="Обновить" Width="100" Click="UpdateRoomBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="DeleteRoomBtn" Content="Удалить" Width="100" Click="DeleteRoomBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="RefreshRoomBtn" Content="Обновить список" Width="120" Click="RefreshRoomBtn_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="RoomDataGrid" AutoGenerateColumns="True" Height="420" MouseDoubleClick="RoomDataGrid_MouseDoubleClick"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Управление энергопотреблением">
                <Grid Background="White">
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Помещение:" VerticalAlignment="Center" Width="100"/>
                            <ComboBox x:Name="EnergyRoomCombo" Width="200" Margin="10,0"/>
                            <TextBlock Text="Дата:" VerticalAlignment="Center" Width="50" Margin="20,0,0,0"/>
                            <DatePicker x:Name="EnergyDatePicker" Width="120" Margin="10,0"/>
                            <TextBlock Text="Период:" VerticalAlignment="Center" Width="60" Margin="20,0,0,0"/>
                            <ComboBox x:Name="EnergyTimePeriodCombo" Width="150" Margin="10,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="Значение энергии (кВтч):" VerticalAlignment="Center" Width="150"/>
                            <TextBox x:Name="EnergyValueTextBox" Width="100" Margin="10,0"/>
                            <Button x:Name="AddEnergyBtn" Content="Добавить" Width="100" Click="AddEnergyBtn_Click" Margin="20,0,10,0"/>
                            <Button x:Name="UpdateEnergyBtn" Content="Обновить" Width="100" Click="UpdateEnergyBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="DeleteEnergyBtn" Content="Удалить" Width="100" Click="DeleteEnergyBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="RefreshEnergyBtn" Content="Обновить" Width="100" Click="RefreshEnergyBtn_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="EnergyDataGrid" AutoGenerateColumns="True" Height="380" MouseDoubleClick="EnergyDataGrid_MouseDoubleClick"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="SQL консоль">
                <Grid Background="White">
                    <StackPanel Margin="20">
                        <TextBlock Text="SQL запрос:" Margin="0,0,0,5"/>
                        <TextBox x:Name="SqlQueryTextBox" Height="150" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" FontFamily="Courier New" Foreground="Black" Background="WhiteSmoke"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button x:Name="ExecuteQueryBtn" Content="Выполнить запрос" Width="150" Click="ExecuteQueryBtn_Click" Margin="0,0,10,0"/>
                            <Button x:Name="ClearQueryBtn" Content="Очистить" Width="100" Click="ClearQueryBtn_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="SqlResultStatus" Text="Результаты:" Margin="0,0,0,5" FontWeight="Bold"/>
                        <DataGrid x:Name="SqlResultGrid" AutoGenerateColumns="True" Height="380"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Формирование отчетов">
                <Grid Background="White">
                    <StackPanel Margin="20">
                        <TabControl>
                            <TabItem Header="Отчет об энергопотреблении">
                                <StackPanel Margin="20">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="Дата начала:" VerticalAlignment="Center" Width="100"/>
                                        <DatePicker x:Name="ReportStartDatePicker" Width="120" Margin="10,0"/>
                                        <TextBlock Text="Дата конца:" VerticalAlignment="Center" Width="100" Margin="20,0,0,0"/>
                                        <DatePicker x:Name="ReportEndDatePicker" Width="120" Margin="10,0"/>
                                        <Button x:Name="GenerateEnergyReportBtn" Content="Генерировать отчет" Width="150" Click="GenerateEnergyReportBtn_Click" Margin="20,0,0,0"/>
                                    </StackPanel>
                                    <DataGrid x:Name="EnergyReportGrid" AutoGenerateColumns="True" Height="450"/>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Статистика по зданиям">
                                <StackPanel Margin="20">
                                    <Button x:Name="GenerateStatisticsBtn" Content="Генерировать статистику" Width="150" Click="GenerateStatisticsBtn_Click" Margin="0,0,0,15"/>
                                    <DataGrid x:Name="StatisticsGrid" AutoGenerateColumns="True" Height="480"/>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
