<Window x:Class="kursach.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Личный кабинет пользователя" Height="700" Width="1000" 
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <DockPanel>
        <!-- Панель заголовка -->
        <StackPanel DockPanel.Dock="Top" Height="60" Background="#2196F3" Orientation="Horizontal" Margin="20">
            <TextBlock x:Name="WelcomeText" Text="Добро пожаловать!" 
                       FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            <Button Content="Выход" Height="35" Width="100" Margin="Auto,0,0,0" 
                    Background="#f44336" Foreground="White" FontSize="12" FontWeight="Bold"
                    Click="LogoutButton_Click" Cursor="Hand"/>
        </StackPanel>

        <!-- Основное содержимое -->
        <TabControl DockPanel.Dock="Bottom">
            <!-- Вкладка 1: Просмотр зданий -->
            <TabItem Header="Здания" Margin="10">
                <StackPanel Margin="10">
                    <TextBlock Text="Список зданий" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid x:Name="BuildingDataGrid" Height="500" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False" Margin="0,0,0,10"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка 2: Просмотр помещений -->
            <TabItem Header="Помещения" Margin="10">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Фильтр по зданию:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="RoomBuildingFilter" Width="200" Height="30" 
                                  DisplayMemberPath="BuildingName" SelectedValuePath="BuildingID"
                                  SelectionChanged="RoomBuildingFilter_SelectionChanged"/>
                        <Button Content="Показать все" Height="30" Width="100" Margin="10,0,0,0"
                                Click="ShowAllRooms_Click" Cursor="Hand"/>
                    </StackPanel>
                    <DataGrid x:Name="RoomDataGrid" Height="450" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка 3: Просмотр энергопотребления -->
            <TabItem Header="Энергопотребление" Margin="10">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Здание:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="EnergyBuildingFilter" Width="150" Height="30" 
                                  DisplayMemberPath="BuildingName" SelectedValuePath="BuildingID"
                                  SelectionChanged="EnergyFilter_SelectionChanged" Margin="0,0,20,0"/>

                        <TextBlock Text="Помещение:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="EnergyRoomFilter" Width="150" Height="30" 
                                  DisplayMemberPath="RoomID" SelectedValuePath="RoomID"
                                  SelectionChanged="EnergyFilter_SelectionChanged" Margin="0,0,20,0"/>

                        <TextBlock Text="Период:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="EnergyPeriodFilter" Width="150" Height="30" 
                                  DisplayMemberPath="PeriodName" SelectedValuePath="TimePeriodID"
                                  SelectionChanged="EnergyFilter_SelectionChanged"/>
                    </StackPanel>
                    <DataGrid x:Name="EnergyDataGrid" Height="430" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка 4: Поиск данных -->
            <TabItem Header="Поиск" Margin="10">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Зданием:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="SearchBuildingFilter" Width="150" Height="30" 
                                  DisplayMemberPath="BuildingName" SelectedValuePath="BuildingID" Margin="0,0,20,0"/>

                        <TextBlock Text="От даты:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="SearchFromDate" Width="150" Height="30" Margin="0,0,20,0"/>

                        <TextBlock Text="До даты:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="SearchToDate" Width="150" Height="30" Margin="0,0,20,0"/>

                        <Button Content="Искать" Height="30" Width="100" 
                                Click="SearchButton_Click" Cursor="Hand"/>
                    </StackPanel>
                    <DataGrid x:Name="SearchDataGrid" Height="430" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка 5: Отчеты и статистика -->
            <TabItem Header="Отчеты" Margin="10">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Тип отчета:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="ReportTypeCombo" Width="200" Height="30" Margin="0,0,20,0">
                            <ComboBoxItem>Общее энергопотребление по зданиям</ComboBoxItem>
                            <ComboBoxItem>Энергопотребление по помещениям</ComboBoxItem>
                            <ComboBoxItem>Энергопотребление по периодам</ComboBoxItem>
                        </ComboBox>
                        <Button Content="Сформировать отчет" Height="30" Width="150" 
                                Click="GenerateReport_Click" Cursor="Hand"/>
                    </StackPanel>
                    <DataGrid x:Name="ReportDataGrid" Height="430" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
