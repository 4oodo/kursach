<Window x:Class="kursach.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Личный кабинет пользователя" Height="700" Width="1200" 
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка: полная ширина, приветствие слева, «Выход» справа -->
        <Border Grid.Row="0" Background="#1976D2" Padding="20,0" SnapsToDevicePixels="True">
            <Grid Height="60">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="WelcomeText" Grid.Column="0" Text="Добро пожаловать!"
                           FontSize="16" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1" Content="Выход" Height="36" MinWidth="100" Padding="16,0"
                        Background="#D32F2F" Foreground="White" FontSize="12" FontWeight="Bold"
                        VerticalAlignment="Center" Click="LogoutButton_Click" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Основное содержимое - TabControl -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- Вкладка 1: Просмотр зданий -->
            <TabItem Header="Здания">
                <StackPanel Margin="10">
                    <TextBlock Text="Список зданий" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid x:Name="BuildingDataGrid" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False" Margin="0,0,0,10"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка 2: Просмотр помещений -->
            <TabItem Header="Помещения">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Фильтр по зданию:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="RoomBuildingFilter" Width="200" Height="30" 
                                  DisplayMemberPath="BuildingName" SelectedValuePath="BuildingID"
                                  SelectionChanged="RoomBuildingFilter_SelectionChanged"/>
                        <Button Content="Показать все" Height="30" Width="100" Margin="10,0,0,0"
                                Click="ShowAllRooms_Click" Cursor="Hand"/>
                    </StackPanel>
                    <DataGrid x:Name="RoomDataGrid" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка 3: Просмотр энергопотребления и фильтрация -->
            <TabItem Header="Энергопотребление">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Фильтры: здание, помещение, дата, время суток (период)" FontSize="12" Foreground="#555" Margin="0,0,0,8"/>
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock Text="Здание:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <ComboBox x:Name="EnergyBuildingFilter" Width="180" Height="30" 
                                      DisplayMemberPath="BuildingName" SelectedValuePath="BuildingID"
                                      SelectionChanged="EnergyBuildingFilter_SelectionChanged" Margin="0,0,16,8"/>

                            <TextBlock Text="Помещение:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <ComboBox x:Name="EnergyRoomFilter" Width="280" Height="30" 
                                      DisplayMemberPath="RoomDisplay" SelectedValuePath="RoomID"
                                      SelectionChanged="EnergyFilter_SelectionChanged" Margin="0,0,16,8"/>

                            <TextBlock Text="Период суток:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <ComboBox x:Name="EnergyPeriodFilter" Width="160" Height="30" 
                                      DisplayMemberPath="PeriodName" SelectedValuePath="TimePeriodID"
                                      SelectionChanged="EnergyFilter_SelectionChanged" Margin="0,0,16,8"/>

                            <TextBlock Text="С даты:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <DatePicker x:Name="EnergyFromDate" Width="130" Height="30" Margin="0,0,12,8"
                                        SelectedDateChanged="EnergyDate_Changed"/>

                            <TextBlock Text="По дату:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <DatePicker x:Name="EnergyToDate" Width="130" Height="30" Margin="0,0,12,8"
                                        SelectedDateChanged="EnergyDate_Changed"/>

                            <Button Content="Сбросить фильтры" Height="30" Width="140" Margin="0,0,8,8"
                                    Click="EnergyResetFilters_Click" Cursor="Hand"/>
                            <Button Content="Обновить" Height="30" Width="100" Margin="0,0,0,8"
                                    Click="EnergyRefresh_Click" Cursor="Hand"/>
                        </WrapPanel>
                    </StackPanel>
                    <DataGrid x:Name="EnergyDataGrid" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False"/>
                </DockPanel>
            </TabItem>

            <!-- Вкладка 4: Поиск и фильтрация данных -->
            <TabItem Header="Поиск">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Поиск записей энергопотребления по зданию, помещению, дате и времени суток" FontSize="12" Foreground="#555" Margin="0,0,0,8"/>
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock Text="Здание:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <ComboBox x:Name="SearchBuildingFilter" Width="180" Height="30" 
                                      DisplayMemberPath="BuildingName" SelectedValuePath="BuildingID"
                                      SelectionChanged="SearchBuildingFilter_SelectionChanged" Margin="0,0,16,8"/>

                            <TextBlock Text="Помещение:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <ComboBox x:Name="SearchRoomFilter" Width="280" Height="30" 
                                      DisplayMemberPath="RoomDisplay" SelectedValuePath="RoomID" Margin="0,0,16,8"/>

                            <TextBlock Text="Период суток:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <ComboBox x:Name="SearchPeriodFilter" Width="160" Height="30" 
                                      DisplayMemberPath="PeriodName" SelectedValuePath="TimePeriodID" Margin="0,0,16,8"/>

                            <TextBlock Text="От даты:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <DatePicker x:Name="SearchFromDate" Width="130" Height="30" Margin="0,0,12,8"/>

                            <TextBlock Text="До даты:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <DatePicker x:Name="SearchToDate" Width="130" Height="30" Margin="0,0,12,8"/>

                            <TextBlock Text="Текст:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox x:Name="SearchTextBox" Width="160" Height="28" VerticalContentAlignment="Center"
                                     ToolTip="Поиск по подписи помещения или названию периода" Margin="0,0,12,8"/>

                            <Button Content="Искать" Height="30" Width="100" Margin="0,0,8,8"
                                    Click="SearchButton_Click" Cursor="Hand"/>
                            <Button Content="Сбросить" Height="30" Width="100" Margin="0,0,0,8"
                                    Click="SearchReset_Click" Cursor="Hand"/>
                        </WrapPanel>
                        <TextBlock x:Name="SearchResultText" Margin="0,4,0,0" Foreground="#666" FontSize="12"/>
                    </StackPanel>
                    <DataGrid x:Name="SearchDataGrid" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False"/>
                </DockPanel>
            </TabItem>

            <!-- Вкладка 5: Отчеты и статистика -->
            <TabItem Header="Отчеты и статистика">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Отчёты по выборке в БД и сводная статистика по зданиям" FontSize="12" Foreground="#555" Margin="0,0,0,8"/>
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock Text="Тип:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <ComboBox x:Name="ReportTypeCombo" Width="320" Height="30" Margin="0,0,12,8">
                                <ComboBoxItem Content="Общее энергопотребление по зданиям"/>
                                <ComboBoxItem Content="Энергопотребление по помещениям (детализация)"/>
                                <ComboBoxItem Content="Энергопотребление по периодам суток"/>
                                <ComboBoxItem Content="Статистика по зданиям (кол-во помещений, сумма, среднее, min/max)"/>
                            </ComboBox>
                            <TextBlock Text="Период для детального отчёта:" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,8,8"/>
                            <DatePicker x:Name="ReportFromDate" Width="120" Height="30" Margin="0,0,8,8"/>
                            <DatePicker x:Name="ReportToDate" Width="120" Height="30" Margin="0,0,12,8"/>
                            <Button Content="Сформировать" Height="30" Width="130" Margin="0,0,8,8"
                                    Click="GenerateReport_Click" Cursor="Hand"/>
                        </WrapPanel>
                    </StackPanel>
                    <DataGrid x:Name="ReportDataGrid" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False"/>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
