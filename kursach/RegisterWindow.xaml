<Window x:Class="kursach.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="500" Width="450" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Width="350" Margin="0,20,0,0">
        <TextBlock Text="Регистрация нового пользователя" 
                   FontSize="14" FontWeight="Bold" 
                   Foreground="#333" TextAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Text="Имя пользователя:" Margin="0,0,0,5" FontWeight="Bold" FontSize="11"/>
        <TextBox x:Name="UsernameTextBox" Height="35" Padding="10,8" 
                 FontSize="12" Margin="0,0,0,10"/>

        <TextBlock Text="Пароль:" Margin="0,0,0,5" FontWeight="Bold" FontSize="11"/>
        <PasswordBox x:Name="PasswordBox" Height="35" Padding="10,8" 
                     FontSize="12" Margin="0,0,0,10"/>

        <TextBlock Text="Подтверждение пароля:" Margin="0,0,0,5" FontWeight="Bold" FontSize="11"/>
        <PasswordBox x:Name="ConfirmPasswordBox" Height="35" Padding="10,8" 
                     FontSize="12" Margin="0,0,0,15"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="IsAdminCheckBox" Content="Зарегистрироваться как администратор" 
                      VerticalAlignment="Center" Checked="IsAdminCheckBox_Checked" Unchecked="IsAdminCheckBox_Unchecked"/>
        </StackPanel>

        <TextBlock x:Name="AdminKeyLabel" Text="Ключ администратора:" Margin="0,0,0,5" FontWeight="Bold" FontSize="11" Visibility="Collapsed"/>
        <TextBox x:Name="AdminKeyTextBox" Height="35" Padding="10,8" 
                 FontSize="12" Margin="0,0,0,15" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Зарегистрироваться" Height="40" Background="#4CAF50" 
                    Foreground="White" FontSize="12" FontWeight="Bold" Width="160"
                    Click="RegisterButton_Click" Cursor="Hand" Margin="0,0,10,0"/>

            <Button Content="Отмена" Height="40" Background="#f44336" 
                    Foreground="White" FontSize="12" FontWeight="Bold" Width="160"
                    Click="CancelButton_Click" Cursor="Hand"/>
        </StackPanel>

        <TextBlock x:Name="ErrorMessage" Text="" Foreground="#D32F2F" 
                   TextWrapping="Wrap" Margin="0,10,0,0" TextAlignment="Center" FontSize="11" FontWeight="Bold"/>
    </StackPanel>
</Window>
