<Window x:Class="kursach.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="400" Width="400" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <TextBlock Text="Регистрация нового пользователя" 
                   FontSize="16" FontWeight="Bold" 
                   Foreground="#333" TextAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Text="Имя пользователя:" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="UsernameTextBox" Height="35" Padding="10,8" 
                 FontSize="12" Margin="0,0,0,10"/>

        <TextBlock Text="Пароль:" Margin="0,0,0,5" FontWeight="Bold"/>
        <PasswordBox x:Name="PasswordBox" Height="35" Padding="10,8" 
                     FontSize="12" Margin="0,0,0,10"/>

        <TextBlock Text="Email:" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="EmailTextBox" Height="35" Padding="10,8" 
                 FontSize="12" Margin="0,0,0,10"/>

        <TextBlock Text="Полное имя:" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="FullNameTextBox" Height="35" Padding="10,8" 
                 FontSize="12" Margin="0,0,0,20"/>

        <Button Content="Зарегистрироваться" Height="40" Background="#4CAF50" 
                Foreground="White" FontSize="14" FontWeight="Bold"
                Click="RegisterButton_Click" Cursor="Hand" Margin="0,0,0,10"/>

        <Button Content="Отмена" Height="40" Background="#f44336" 
                Foreground="White" FontSize="14" FontWeight="Bold"
                Click="CancelButton_Click" Cursor="Hand"/>

        <TextBlock x:Name="ErrorMessage" Text="" Foreground="Red" 
                   TextWrapping="Wrap" Margin="0,15,0,0" TextAlignment="Center"/>
    </StackPanel>
</Window>
