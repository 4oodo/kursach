<Window x:Class="kursach.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="350" Width="450" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
        <TextBlock Text="Система управления энергопотреблением" 
                   FontSize="18" FontWeight="Bold" 
                   Foreground="#1976D2" TextAlignment="Center" Margin="0,0,0,30"/>

        <TextBlock Text="Вход в систему" 
                   FontSize="14" FontWeight="Bold" 
                   Foreground="#333" Margin="0,0,0,20"/>

        <TextBlock Text="Имя пользователя:" Margin="0,0,0,5" FontWeight="Bold" FontSize="12"/>
        <TextBox x:Name="UsernameTextBox" Height="40" Padding="10,10" 
                 FontSize="13" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

        <TextBlock Text="Пароль:" Margin="0,0,0,5" FontWeight="Bold" FontSize="12"/>
        <PasswordBox x:Name="PasswordBox" Height="40" Padding="10,10" 
                     FontSize="13" Margin="0,0,0,25" VerticalContentAlignment="Center"/>

        <Button Content="Войти" Height="45" Background="#4CAF50" 
                Foreground="White" FontSize="14" FontWeight="Bold"
                Click="LoginButton_Click" Cursor="Hand" Margin="0,0,0,12" MouseEnter="LoginButton_MouseEnter" MouseLeave="LoginButton_MouseLeave"/>

        <Button Content="Зарегистрироваться" Height="45" Background="#2196F3" 
                Foreground="White" FontSize="14" FontWeight="Bold"
                Click="RegisterButton_Click" Cursor="Hand" MouseEnter="RegisterButton_MouseEnter" MouseLeave="RegisterButton_MouseLeave"/>

        <TextBlock x:Name="ErrorMessage" Text="" Foreground="#D32F2F" 
                   TextWrapping="Wrap" Margin="0,20,0,0" TextAlignment="Center" FontSize="12" FontWeight="Bold"/>
    </StackPanel>
</Window>
