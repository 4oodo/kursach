<Window x:Class="kursach.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="300" Width="400" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <TextBlock Text="Система управления энергопотреблением" 
                   FontSize="16" FontWeight="Bold" 
                   Foreground="#333" TextAlignment="Center" Margin="0,0,0,30"/>

        <TextBlock Text="Имя пользователя:" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="UsernameTextBox" Height="35" Padding="10,8" 
                 FontSize="12" Margin="0,0,0,15"/>

        <TextBlock Text="Пароль:" Margin="0,0,0,5" FontWeight="Bold"/>
        <PasswordBox x:Name="PasswordBox" Height="35" Padding="10,8" 
                     FontSize="12" Margin="0,0,0,20"/>

        <Button Content="Войти" Height="40" Background="#4CAF50" 
                Foreground="White" FontSize="14" FontWeight="Bold"
                Click="LoginButton_Click" Cursor="Hand" Margin="0,0,0,10"/>

        <Button Content="Зарегистрироваться" Height="40" Background="#2196F3" 
                Foreground="White" FontSize="14" FontWeight="Bold"
                Click="RegisterButton_Click" Cursor="Hand"/>

        <TextBlock x:Name="ErrorMessage" Text="" Foreground="Red" 
                   TextWrapping="Wrap" Margin="0,15,0,0" TextAlignment="Center"/>
    </StackPanel>
</Window>
